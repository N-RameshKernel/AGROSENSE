# ── AgroSense Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values before running.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agrosense:agrosense@localhost:5432/agrosense

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LLM Inference ─────────────────────────────────────────────────────────────
# For GPU (vLLM):  http://localhost:8080
# For CPU (Ollama): http://localhost:8080  (mapped via docker-compose)
LLM_SERVER_URL=http://localhost:8080
LLM_MODEL_NAME=agrosense-v1.2

# ── Auth ──────────────────────────────────────────────────────────────────────
# CHANGE THIS in production — any long random string works.
JWT_SECRET=change-me-in-production-please

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── LLMOps ───────────────────────────────────────────────────────────────────
# Path to the base model used for fine-tuning
BASE_MODEL_PATH=mistralai/Mistral-7B-Instruct-v0.2
# Local directory where fine-tuned model checkpoints are saved
MODELS_DIR=./models

# ── HuggingFace (optional — only needed to pull gated models) ─────────────────
HF_TOKEN=
